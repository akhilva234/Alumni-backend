generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  user_id            Int                   @id @default(autoincrement())
  first_name         String
  last_name          String
  user_photo         String? 
  email              String                @unique
  phone_number       String
  date_of_birth      DateTime
  gender             String?
  current_address    String?
  password           String
  is_blocked         Boolean              @default(false)
  location           String?


  role            Role            @default(ALUMNI)
  marital_status  MaritalStatus   @default(Unmarried)
  approved_status     ApprovedStatus  @default(PENDING)
  academicDetails    Academic_Detail[]
   externalEducation  External_Education[]
  professionalDetails Professional_Detail[]

  // Relations for Posts
  posts               Post[]
  comments            Comment[]
  likes               Like[]
  
  // Relations for Chats
  groupMemberships    GroupMember[]
  messagesSent        Message[]
  
  // Relations for Events & Donations
  eventsOrganized     Event[]       @relation("EventOrganizer")
  donations           Donation[]

  // Faculty subtype profile
  facultyProfile      Faculty_Profile?

  // Principal subtype profile
  principalProfile    Principal_Profile?
}

model Academic_Detail {
  academic_id        Int         @id @default(autoincrement())
  user_id            Int
  prn_number         String      @unique
  adm_year           Int
  graduation_year    Int
  course_id          Int
  degree_certificate String?
  user               User        @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  course             Course                @relation(fields: [course_id], references: [course_id])
}

model External_Education {
  external_id       Int       @id @default(autoincrement())
  user_id           Int
  degree_id         Int?      
  course_name       String?   
  college_name      String? 
  start_year        Int?
  end_year          Int?

  user              User      @relation(fields: [user_id], references: [user_id])
  degree            Degree?   @relation(fields: [degree_id], references: [degree_id])
}

model Degree {
  degree_id       Int               @id @default(autoincrement())
  degree_name     String            @unique
  externalEducation External_Education[]
  courses         Course[]
}

model Department {
  department_id   Int               @id @default(autoincrement())
  department_name String            @unique
  courses         Course[]
  chatGroups      ChatGroup[]
  facultyProfiles Faculty_Profile[]
}

model Course {
  course_id     Int        @id @default(autoincrement())
  course_name   String
  course_code   String
  department_id Int
  degree_id     Int
  department    Department @relation(fields: [department_id], references: [department_id])
  degree        Degree     @relation(fields: [degree_id], references: [degree_id])
  academicDetails   Academic_Detail[]
  
}

model Professional_Detail {
  professional_id  Int       @id @default(autoincrement())
  user_id          Int
  current_position String?
  company_name     String?
  experience       Float?          @default(0)
  industry_id      Int?
  work_email       String?
  linkedin_profile String?
  instagram        String?
  key_skills       String?
  industry         Industry? @relation(fields: [industry_id], references: [industry_id])
  user             User      @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
}

model Industry {
  industry_id   Int                   @id @default(autoincrement())
  industry_name String                @unique
  professionals Professional_Detail[]
}

// Faculty department association (subtype table — same pattern as Academic_Detail)
model Faculty_Profile {
  profile_id    Int        @id @default(autoincrement())
  user_id       Int        @unique               // one profile per faculty
  department_id Int
  joined_date   DateTime?                        // optional: when they joined the dept
  user          User       @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  department    Department @relation(fields: [department_id], references: [department_id])
}

// Principal association (subtype table)
model Principal_Profile {
  profile_id    Int        @id @default(autoincrement())
  user_id       Int        @unique               // one profile per principal
  department    String?
  joined_date   DateTime
  end_date      DateTime?
  status        String     @default("active")    // "active" or "inactive"
  user          User       @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
}

enum Role {
  ADMIN
  ALUMNI
  FACULTY
  RETD_FACULTY
  PRINCIPAL
  EX_PRINCIPAL
}

enum ApprovedStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MaritalStatus{
  Married
  Unmarried
  Divorced
}

// -----------------------------------------------------------------------------
// POSTS (Feed & Jobs)
// -----------------------------------------------------------------------------

model Post {
  post_id     Int       @id @default(autoincrement())
  user_id     Int
  content     String
  image_url   String?
  post_type   PostType  @default(GENERAL)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  user        User      @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  comments    Comment[]
  likes       Like[]
}

enum PostType {
  GENERAL
  JOB
}

model Comment {
  comment_id  Int       @id @default(autoincrement())
  post_id     Int
  user_id     Int
  content     String
  created_at  DateTime  @default(now())

  post        Post      @relation(fields: [post_id], references: [post_id], onDelete: Cascade)
  user        User      @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
}

model Like {
  like_id     Int       @id @default(autoincrement())
  post_id     Int
  user_id     Int

  post        Post      @relation(fields: [post_id], references: [post_id], onDelete: Cascade)
  user        User      @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@unique([post_id, user_id])
}

// -----------------------------------------------------------------------------
// CHATS (Batch, Department, College Level)
// -----------------------------------------------------------------------------

model ChatGroup {
  group_id      Int       @id @default(autoincrement())
  name          String
  group_type    GroupType
  
  // Optional identifiers for specific group types
  department_id Int?
  batch_year    Int?

  created_at    DateTime  @default(now())

  messages      Message[]
  members       GroupMember[]
  department    Department? @relation(fields: [department_id], references: [department_id])
}

enum GroupType {
  COLLEGE
  DEPARTMENT
  BATCH
}

model GroupMember {
  member_id     Int       @id @default(autoincrement())
  group_id      Int
  user_id       Int
  joined_at     DateTime  @default(now())

  group         ChatGroup @relation(fields: [group_id], references: [group_id], onDelete: Cascade)
  user          User      @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@unique([group_id, user_id])
}

model Message {
  message_id    Int       @id @default(autoincrement())
  group_id      Int
  sender_id     Int
  content       String
  sent_at       DateTime  @default(now())

  group         ChatGroup @relation(fields: [group_id], references: [group_id], onDelete: Cascade)
  sender        User      @relation(fields: [sender_id], references: [user_id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// EVENTS & DONATIONS
// -----------------------------------------------------------------------------

model Event {
  event_id      Int       @id @default(autoincrement())
  title         String
  description   String
  image_url     String?
  event_date    DateTime
  event_time    String?
  location      String?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  organizer_id  Int
  organizer     User      @relation("EventOrganizer", fields: [organizer_id], references: [user_id])

  donations     Donation[]
}

model Donation {
  donation_id   Int       @id @default(autoincrement())
  event_id      Int
  donor_id      Int
  amount        Float
  message       String?
  donated_at    DateTime  @default(now())
  status        DonationStatus @default(PENDING)

  event         Event     @relation(fields: [event_id], references: [event_id], onDelete: Cascade)
  donor         User      @relation(fields: [donor_id], references: [user_id], onDelete: Cascade)
}

enum DonationStatus {
  PENDING
  SUCCESS
  FAILED
}
